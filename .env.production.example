# =============================================================================
# PRODUCTION environment variable reference for Multi-Auth
# Do NOT commit a real .env — this file is the template only.
# Real values are stored in Jenkins Credentials and written to the server at
# deploy time by the Jenkinsfile (withCredentials block).
# =============================================================================

# ── Database (AWS RDS PostgreSQL) ─────────────────────────────────────────────
# Use ?sslmode=require for RDS
DATABASE_URL=postgresql://USER:PASSWORD@your-rds-endpoint:5432/multiauth_db?sslmode=require
DB_SSL=true

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
DOMAIN=https://app.YOUR_IP.nip.io

# ── JWT RSA Keys (REQUIRED) ───────────────────────────────────────────────────
# Generate with: node scripts/setup-keys.js
# Store as single-line strings with \n for newlines.
# See KEYS_SETUP.md in this repo for full generation instructions.
JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----

JWT_ACCESS_TOKEN_EXPIRE=900
JWT_REFRESH_TOKEN_EXPIRE=604800

# ── CORS & Cookies ────────────────────────────────────────────────────────────
CORS_ORIGIN=https://app.YOUR_IP.nip.io
COOKIE_SAMESITE=strict
COOKIE_DOMAIN=.YOUR_IP.nip.io

# ── OAuth Clients ─────────────────────────────────────────────────────────────
# Change all secrets before production use — these are illustrative values only
HRM_CLIENT_ID=hrm-app
HRM_CLIENT_SECRET=CHANGE_ME_hrm_secret
CRM_CLIENT_ID=crm-app
CRM_CLIENT_SECRET=CHANGE_ME_crm_secret
